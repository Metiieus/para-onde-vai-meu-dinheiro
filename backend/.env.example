# =============================================
# Para Onde Vai Meu Dinheiro - Configuração
# =============================================
# Copie este arquivo para .env e preencha os valores

# --- Redis ---
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# --- Servidor ---
PORT=8000
HOST=0.0.0.0

# --- Ambiente ---
ENVIRONMENT=development
DEBUG=true

# --- Segurança ---
# Chave secreta para proteger o endpoint /api/cache/clear
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
CACHE_ADMIN_KEY=

# --- CORS ---
# Em produção, substitua "*" pelo domínio do seu frontend (ex: https://meusite.com.br)
# Separe múltiplas origens com vírgula
ALLOWED_ORIGINS=*
